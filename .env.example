# Bluesky — create an app password at https://bsky.app/settings/app-passwords
BLUESKY_HANDLE=you.bsky.social
BLUESKY_APP_PASSWORD=

# Fedi (Mastodon API compatible) — run ./setup-fedi-auth.sh to set these up
FEDI_INSTANCE_URL=https://mastodon.social
FEDI_ACCESS_TOKEN=
FEDI_CLIENT_ID=
FEDI_CLIENT_SECRET=
FEDI_CHAR_LIMIT=3000

# Optional: Anthropic API key for AI alt text generation
# Without this, alt text generation will use Claude Code CLI if installed
ANTHROPIC_API_KEY=

# Server
PORT=3000
